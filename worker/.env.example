# Redis URL for Celery broker
REDIS_URL=redis://localhost:6379/0

# PostgreSQL configuration
PGHOST=localhost
PGPORT=5432
PGDATABASE=douyin
PGUSER=postgres
PGPASSWORD=postgres

# Schedule configuration (24-hour format, Asia/Shanghai timezone)
SCHEDULE_HOUR=4
SCHEDULE_MINUTE=0

# Batch size - number of videos to process per scheduled run
BATCH_SIZE=20
STALE_PROCESSING_HOURS=24
ORPHAN_FILE_GRACE_HOURS=24

# WebGemini polling
WEBGEMINI_POLL_INTERVAL=5
WEBGEMINI_POLL_MAX_WAIT=1800

# Skip oversized video downloads before writing file (3 GiB default)
MAX_DOWNLOAD_SIZE_BYTES=3221225472

# Compress videos with ffmpeg before upload
ENABLE_VIDEO_COMPRESSION=true
VIDEO_COMPRESSION_CRF=32
VIDEO_COMPRESSION_PRESET=veryfast

# Telegram (same names as blog2media; copy values from blog2media .env if needed)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_CHAT_ID=
# Or: CTI_TG_BOT_TOKEN= / CTI_TG_CHAT_ID=

# BitStripe batch report upload (optional; defaults match bitstripe-uploader skill)
# BITSTRIPE_UPLOAD_SCRIPT=~/.cursor/skills/bitstripe-uploader/scripts/upload.sh
# BITSTRIPE_URL_PREFIX=https://www.bitstripe.cn/files/
