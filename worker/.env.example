# Redis URL for Celery broker
REDIS_URL=redis://localhost:6379/0

# PostgreSQL configuration
PGHOST=localhost
PGPORT=5432
PGDATABASE=douyin
PGUSER=postgres
PGPASSWORD=postgres

# Schedule configuration (24-hour format, Asia/Shanghai timezone)
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# Batch size - number of videos to process per scheduled run
BATCH_SIZE=20
